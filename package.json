{
  "name": "effect-uai-monorepo",
  "version": "0.0.0",
  "private": true,
  "description": "Low-level primitives for AI agents in Effect.",
  "keywords": [
    "agents",
    "ai",
    "effect",
    "llm",
    "openai",
    "streaming",
    "typescript"
  ],
  "homepage": "https://effect-uai.betalyra.com",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai"
  },
  "type": "module",
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "pnpm -r typecheck",
    "typecheck:core": "pnpm --filter @effect-uai/core typecheck",
    "typecheck:responses": "pnpm --filter @effect-uai/responses typecheck",
    "typecheck:recipes": "pnpm --filter @effect-uai/recipes typecheck",
    "typecheck:webpage": "pnpm --filter webpage typecheck",
    "format": "oxfmt",
    "format:check": "oxfmt --check",
    "dev:webpage": "pnpm --filter webpage dev",
    "build:webpage": "pnpm --filter webpage build",
    "preview:webpage": "pnpm --filter webpage preview"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "oxfmt": "^0.46.0",
    "tsx": "^4.21.0",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "packageManager": "pnpm@10.18.3"
}
