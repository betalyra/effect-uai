{
  "name": "@effect-uai/elevenlabs",
  "version": "0.4.0",
  "description": "ElevenLabs speech-to-text and text-to-speech provider for @effect-uai/core.",
  "keywords": [
    "ai",
    "effect",
    "elevenlabs",
    "speech",
    "stt",
    "transcription",
    "tts"
  ],
  "homepage": "https://github.com/betalyra/effect-uai/tree/main/packages/providers/elevenlabs",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai",
    "directory": "packages/providers/elevenlabs"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./ElevenLabsSynthesizer": {
      "types": "./dist/ElevenLabsSynthesizer.d.mts",
      "import": "./dist/ElevenLabsSynthesizer.mjs"
    },
    "./ElevenLabsTranscriber": {
      "types": "./dist/ElevenLabsTranscriber.d.mts",
      "import": "./dist/ElevenLabsTranscriber.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@effect-uai/core": "workspace:*",
    "effect": "4.0.0-beta.57",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@effect-uai/core": "workspace:>=0.2.0 <1",
    "effect": "4.0.0-beta.57"
  }
}
