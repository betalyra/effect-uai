      "types": "./dist/ExaSearch.d.mts",
      "import": "./dist/ExaSearch.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@effect-uai/core": "workspace:*",
    "effect": "4.0.0-beta.57",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@effect-uai/core": "workspace:>=0.2.0 <1",
    "effect": "4.0.0-beta.57"
