{
  "name": "@effect-uai/exa",
  "version": "0.7.0",
  "description": "Exa provider for @effect-uai/core (web search).",
  "keywords": [
    "ai",
    "effect",
    "exa",
    "search",
    "web-search"
  ],
  "homepage": "https://github.com/betalyra/effect-uai/tree/main/packages/providers/exa",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai",
    "directory": "packages/providers/exa"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
