{
  "name": "@effect-uai/google",
  "version": "0.2.0",
  "description": "Google Gemini provider for @effect-uai/core.",
  "keywords": [
    "ai",
    "effect",
    "gemini",
    "google",
    "llm"
  ],
  "homepage": "https://github.com/betalyra/effect-uai/tree/main/packages/providers/google",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai",
    "directory": "packages/providers/google"
  },
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./Gemini": {
      "types": "./dist/Gemini.d.mts",
      "import": "./dist/Gemini.mjs"
    },
    "./GeminiEmbedding": {
      "types": "./dist/GeminiEmbedding.d.mts",
      "import": "./dist/GeminiEmbedding.mjs"
    }
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "peerDependencies": {
    "@effect-uai/core": "workspace:^",
    "effect": "4.0.0-beta.57"
  },
  "devDependencies": {
    "@effect-uai/core": "workspace:*",
    "effect": "4.0.0-beta.57",
    "typescript": "^6.0.3"
  }
}
