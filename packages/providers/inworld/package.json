{
  "name": "@effect-uai/inworld",
  "version": "0.7.0",
  "description": "Inworld speech-to-text and text-to-speech provider for @effect-uai/core.",
  "keywords": [
    "ai",
    "effect",
    "inworld",
    "speech",
    "stt",
    "transcription",
    "tts"
  ],
  "homepage": "https://github.com/betalyra/effect-uai/tree/main/packages/providers/inworld",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai",
    "directory": "packages/providers/inworld"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./InworldSynthesizer": {
      "types": "./dist/InworldSynthesizer.d.mts",
      "import": "./dist/InworldSynthesizer.mjs"
    },
    "./InworldRealtimeSynthesizer": {
      "types": "./dist/InworldRealtimeSynthesizer.d.mts",
      "import": "./dist/InworldRealtimeSynthesizer.mjs"
    },
    "./InworldTranscriber": {
      "types": "./dist/InworldTranscriber.d.mts",
      "import": "./dist/InworldTranscriber.mjs"
    },
    "./InworldRealtimeTranscriber": {
      "types": "./dist/InworldRealtimeTranscriber.d.mts",
      "import": "./dist/InworldRealtimeTranscriber.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@effect-uai/core": "workspace:*",
    "@types/ws": "^8.5.13",
    "effect": "4.0.0-beta.57",
    "typescript": "^6.0.3",
    "ws": "^8.18.0"
  },
  "peerDependencies": {
    "@effect-uai/core": "workspace:>=0.2.0 <1",
    "effect": "4.0.0-beta.57",
    "ws": "^8.0.0"
  },
  "peerDependenciesMeta": {
    "ws": {
      "optional": true
    }
  }
}
