{
  "name": "@effect-uai/responses",
  "version": "0.6.0",
  "description": "OpenAI Responses API provider for @effect-uai/core.",
  "keywords": [
    "ai",
    "effect",
    "llm",
    "openai",
    "responses-api"
  ],
  "homepage": "https://github.com/betalyra/effect-uai/tree/main/packages/providers/responses",
  "bugs": {
    "url": "https://github.com/betalyra/effect-uai/issues"
  },
  "license": "MIT",
  "author": "Betalyra",
  "repository": {
    "type": "git",
    "url": "https://github.com/betalyra/effect-uai",
    "directory": "packages/providers/responses"
  },
  "files": [
    "dist",
    "src",
    "README.md",
    "LICENSE"
  ],
  "type": "module",
  "main": "./dist/index.mjs",
  "types": "./dist/index.d.mts",
  "exports": {
    ".": {
      "types": "./dist/index.d.mts",
      "import": "./dist/index.mjs"
    },
    "./Responses": {
      "types": "./dist/Responses.d.mts",
      "import": "./dist/Responses.mjs"
    },
    "./OpenAIEmbedding": {
      "types": "./dist/OpenAIEmbedding.d.mts",
      "import": "./dist/OpenAIEmbedding.mjs"
    }
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "pnpm typecheck && pnpm build"
  },
  "devDependencies": {
    "@effect-uai/core": "workspace:*",
    "effect": "4.0.0-beta.57",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@effect-uai/core": "workspace:>=0.2.0 <1",
    "effect": "4.0.0-beta.57"
  }
}
